modules = ["nodejs-20", "nix"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Naruto Bot"

[[workflows.workflow]]
name = "Naruto Bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node src/index.js"

[workflows.workflow.metadata]
outputType = "console"

[deployment]
deploymentTarget = "vm"
run = ["node", "src/index.js"]

[[ports]]
localPort = 5000
externalPort = 80

[userenv]

[userenv.shared]
BACKUP_CHANNEL_ID = "1529836338642292857"
